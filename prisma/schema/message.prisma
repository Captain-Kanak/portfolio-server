model Message {
    id        String    @id @default(uuid(7))
    name      String    @db.VarChar(100)
    email     String    @db.VarChar(100)
    message   String    @db.Text
    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([email])
    @@map("messages")
}
