model Project {
    id          String    @id @default(uuid(7))
    title       String
    description String
    images      String[]
    features    String[]
    projectUrl  String
    backendUrl  String
    frontendUrl String
    views       Int       @default(0)
    adminId     String
    isDeleted   Boolean   @default(false)
    deletedAt   DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    technologies ProjectTechnology[]
    feedbacks    Feedback[]

    admin Admin @relation(fields: [adminId], references: [id])

    @@unique([title])
    @@index([projectUrl])
    @@map("projects")
}
